# 小鹅通回放链接。也可以运行时用 REPLAY_URL=... 覆盖。
REPLAY_URL="https://example.com/your-xiaoe-replay"

# 浏览器登录态保存目录。第一次扫码登录后会复用这里。
BROWSER_PROFILE_DIR="./browser-profile/xiaoe"

# 如果 Playwright 自带 Chromium 没装好，可以临时用系统 Chrome。
BROWSER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
BROWSER_DRIVER="playwright"
MANUAL_START_DELAY_SECONDS=20

# 默认完整录制优先：Playwright 检测播放器结束后停止；检测不到时按最长保护时长停止。
RECORD_MODE="complete"
RECORD_SECONDS=14400

# 调试播放按钮时打开。DRY_RUN=1 时只打开页面、检测登录、读标题、尝试点击播放。
DRY_RUN=0

# 强制重跑。会忽略 processed.json，并覆盖本次标题对应的 output/<slug>。
FORCE_RERUN=0

# macOS 系统音频设备名。推荐安装 BlackHole 2ch 后填 BlackHole 2ch。
# 先运行：ffmpeg -f avfoundation -list_devices true -i ""
AUDIO_DEVICE_NAME="BlackHole 2ch"

# 不推荐默认使用编号；不同运行环境里编号可能漂移。
# 只有在完全没有 AUDIO_DEVICE_NAME 且你确认编号稳定时才填。
AUDIO_DEVICE_INDEX=""

# 输出目录
OUTPUT_DIR="./output"

# 如果小鹅通播放按钮不好识别，可以填一个 CSS selector，例如：
# PLAY_BUTTON_SELECTOR=".player-play-button"
PLAY_BUTTON_SELECTOR=""

# 转写方式：local / openai / volcengine
TRANSCRIBE_PROVIDER="local"
WHISPER_MODEL="small"
OPENAI_API_KEY=""

# 火山 ASR。先按你在火山控制台拿到的接口形态填写。
# multipart：把 recording.wav 作为表单文件上传，默认字段名 file。
# json_base64：把 recording.wav 读成 base64 放进 JSON，默认字段名 audio。
VOLCENGINE_ASR_URL=""
VOLCENGINE_ASR_TOKEN=""
VOLCENGINE_ASR_AUTH_HEADER="Authorization"
VOLCENGINE_ASR_AUTH_PREFIX="Bearer"
VOLCENGINE_ASR_REQUEST_FORMAT="multipart"
VOLCENGINE_ASR_FILE_FIELD="file"
VOLCENGINE_ASR_FIELDS_JSON=""
VOLCENGINE_ASR_PAYLOAD_JSON=""
VOLCENGINE_ASR_AUDIO_FIELD="audio"
VOLCENGINE_ASR_AUDIO_FORMAT_FIELD="format"
VOLCENGINE_ASR_AUDIO_FORMAT="wav"
VOLCENGINE_ASR_TEXT_PATH=""
VOLCENGINE_ASR_TIMEOUT=180

# 整理逐字稿用的模型
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4.1-mini"

# 飞书写入：MVP 默认优先使用本机 lark-cli，因为它已经封装了飞书开放平台鉴权。
FEISHU_WRITER="lark-cli"
FEISHU_DOC_PARENT_FOLDER_TOKEN=""

# 飞书多维表格索引。填你的 Base 链接里的 base token / table id / view id。
FEISHU_BASE_TOKEN="KV7cbayMyavYO9sboNVcYF7enGg"
FEISHU_BASE_TABLE_ID="tblgW1ERIuG0MZK6"
FEISHU_BASE_VIEW_ID="vew4Nm4Y6w"
FEISHU_BASE_FIELD_BROAD_ANSWER="广泛解答"
FEISHU_BASE_FIELD_VIDEO_URL="视频链接"
FEISHU_BASE_FIELD_TEXT_URL="文本链接"
FEISHU_BASE_FIELD_SOURCE_ID="SourceID"

# 如果后续改成你自己的开放平台直连，可放这些值。
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
